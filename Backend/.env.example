# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/tourmate

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================================
# PayHere Payment Gateway Configuration
# ===========================================
# Reference: https://www.payhere.lk/
# For sandbox testing: https://sandbox.payhere.lk

# Default payment gateway (options: payhere, stripe, card, bank-transfer)
DEFAULT_PAYMENT_GATEWAY=payhere

# PayHere Merchant Credentials
# Get these from: https://sandbox.payhere.lk (for testing)
# Merchant ID: numeric ID assigned by PayHere
PAYHERE_MERCHANT_ID=1236017

# Merchant Secret: Keep this secret! 
# To encode: echo -n "your-secret" | base64
# To decode: echo -n "encoded-secret" | base64 -d
# Encoding method (options: plain, base64)
PAYHERE_MERCHANT_SECRET_ENCODING=base64
# Example base64-encoded secret for testing (DO NOT use in production!)
PAYHERE_MERCHANT_SECRET=MzE4MTY2OTQ2ODMzMTM1NzY1MDY5NDM0OTIxMDMxMjIyMzU2NDAy

# PayHere Checkout URL
# Sandbox: https://sandbox.payhere.lk/pay/checkout
# Production: https://www.payhere.lk/pay/checkout
PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout

# PayHere Return URL (user redirected after successful payment)
PAYHERE_RETURN_URL=http://localhost:3000/tourist/trips

# PayHere Cancel URL (user redirected if payment is cancelled)
PAYHERE_CANCEL_URL=http://localhost:3000/tourist/requests

# PayHere Notify URL (server-to-server webhook for payment status)
# IMPORTANT: Must be publicly reachable HTTPS URL!
# For local development, use ngrok:
#   1. Install: https://ngrok.com/download
#   2. Run: ngrok http 5000
#   3. Copy ngrok URL: https://xxxx-xx-xxx-xxx-xx.ngrok.io
#   4. Set: PAYHERE_NOTIFY_URL=https://xxxx-xx-xxx-xxx-xx.ngrok.io/api/payments/payhere/notify
PAYHERE_NOTIFY_URL=http://localhost:5000/api/payments/payhere/notify

# Advance payment percentage for tour requests (as % of proposed price)
TOUR_ADVANCE_PAYMENT_PERCENTAGE=25

# Test Card Details (Sandbox Only):
# - Card Number: 4111111111111111
# - Expiry: Any future date (e.g., 12/25)
# - CVV: Any 3 digits (e.g., 123)
# Verify setup with: node verify-payhere.js

# Google OAuth
GOOGLE_CLIENT_ID="357111222243-5k1ap1m0ahnookseucienkuogesibgei.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"

# Frontend URL
FRONTEND_URL=http://localhost:3000
